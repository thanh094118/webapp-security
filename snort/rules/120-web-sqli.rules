alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - Generic Tautology (OR 1=1)"; flow:established,to_server; content:"GET"; http_method; pcre:"/(?:\%27|')\s*(?:OR|AND)\s*(?:\%20|\s)*(?:\d+=\d+|'[a-z]'='[a-z]')/i"; http_uri; classtype:web-application-attack; sid:1000001; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - UNION SELECT Injection Detected"; flow:established,to_server; pcre:"/(?:\%27|')\s*UNION\s+(?:\%20|\s)*SELECT/i"; http_uri; classtype:web-application-attack; sid:1000002; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - Error Based (Information_Schema)"; flow:established,to_server; content:"information_schema"; nocase; http_uri; classtype:web-application-attack; sid:1000003; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - Blind/Time Based (SLEEP)"; flow:established,to_server; pcre:"/SLEEP\s*\(\s*\d+\s*\)/i"; http_uri; classtype:web-application-attack; sid:1000004; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - Blind/Time Based (WAITFOR DELAY)"; flow:established,to_server; content:"WAITFOR"; nocase; http_uri; content:"DELAY"; nocase; http_uri; classtype:web-application-attack; sid:1000005; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - SQLMap User-Agent Detected"; flow:established,to_server; content:"User-Agent|3A|"; http_header; content:"sqlmap"; nocase; http_header; classtype:web-application-attack; sid:1000006; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - DVWA Specific Target (/vulnerabilities/sqli/)"; flow:established,to_server; content:"/DVWA/vulnerabilities/sqli/"; http_uri; pcre:"/id=[^\&]*(?:\%27|')/i"; classtype:web-application-attack; sid:1000007; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - DVWA Blind Target (/vulnerabilities/sqli_blind/)"; flow:established,to_server; content:"/DVWA/vulnerabilities/sqli_blind/"; http_uri; pcre:"/id=[^\&]*(?:\%27|')/i"; classtype:web-application-attack; sid:1000008; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - POST Body Tautology"; flow:established,to_server; content:"POST"; http_method; pcre:"/(?:\%27|')\s*(?:OR|AND)\s*(?:\%20|\s)*(?:\d+=\d+|'[a-z]'='[a-z]')/i"; http_client_body; classtype:web-application-attack; sid:1000009; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - Database Fingerprinting (@@version)"; flow:established,to_server; content:"@@version"; nocase; http_uri; classtype:web-application-attack; sid:1000010; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - DROP TABLE Attempt"; flow:established,to_server; pcre:"/;\s*DROP\s+TABLE/i"; http_uri; classtype:web-application-attack; sid:1000011; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - INTO OUTFILE Attempt"; flow:established,to_server; pcre:"/INTO\s+(?:OUT|DUMP)FILE/i"; http_uri; classtype:web-application-attack; sid:1000012; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - LOAD_FILE Execution"; flow:established,to_server; content:"load_file"; nocase; http_uri; classtype:web-application-attack; sid:1000013; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - System Command Execution (xp_cmdshell)"; flow:established,to_server; content:"xp_cmdshell"; nocase; http_uri; classtype:web-application-attack; sid:1000014; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - Inline Comments Bypass (/**/)"; flow:established,to_server; pcre:"/(?:\%2F|\/)(?:\%2A|\*).*(?:\%2A|\*)(?:\%2F|\/)/i"; http_uri; classtype:web-application-attack; sid:1000015; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - Hex Encoding Evasion Detected"; flow:established,to_server; pcre:"/0x[0-9a-fA-F]{4,}/i"; http_uri; classtype:web-application-attack; sid:1000016; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - Multiple SQL Keywords Sequence"; flow:established,to_server; pcre:"/(?:select|update|delete|insert).+(?:from|into|where|set).+(?:union|order\s+by|group\s+by)/i"; http_uri; classtype:web-application-attack; sid:1000017; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - Havij/Pangolin Signature Detected"; flow:established,to_server; content:"%20--%20"; http_uri; pcre:"/inject(?:ion)?/i"; classtype:web-application-attack; sid:1000018; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - SQLMap Hex Payload Pattern"; flow:established,to_server; pcre:"/CONCAT\((?:0x[0-9a-fA-F]+,)+\)/i"; http_uri; classtype:web-application-attack; sid:1000019; rev:1;)
alert tcp $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"SOC-LAB SQLi - DVWA Admin Authentication Bypass Attempt"; flow:established,to_server; content:"/DVWA/login.php"; http_uri; content:"username="; http_client_body; pcre:"/username=(?:admin|root)(?:\%27|')\s*(?:#|--|\%23)/i"; classtype:web-application-attack; sid:1000020; rev:1;)